{
  "name": "@platform/root",
  "private": true,
  "version": "0.0.0",
  "description": "Premium educational-toys commerce platform — monorepo foundation (Phase 2, Sprint 0.1).",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,yml,yaml}\"",
    "clean": "turbo run clean",
    "gen": "turbo gen",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@platform/eslint-config": "workspace:*",
    "@platform/prettier-config": "workspace:*",
    "@platform/tsconfig": "workspace:*",
    "@turbo/gen": "^2.3.0",
    "eslint": "^9.13.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
