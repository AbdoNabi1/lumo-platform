{
  "name": "@platform/config",
  "version": "0.0.0",
  "private": true,
  "description": "Centralized typed configuration: base env + server-side infrastructure config (environment inheritance) and feature-flag infrastructure. No business config.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@platform/health": "workspace:*",
    "@platform/secrets": "workspace:*",
    "@platform/utils": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@platform/eslint-config": "workspace:*",
    "@platform/tsconfig": "workspace:*",
    "@types/node": "^22.7.5",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
