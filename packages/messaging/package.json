    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@platform/contracts": "workspace:*",
    "@platform/domain": "workspace:*",
    "@platform/domain-events": "workspace:*",
    "@platform/utils": "workspace:*"
  },
  "devDependencies": {
    "@platform/eslint-config": "workspace:*",
    "@platform/tsconfig": "workspace:*",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
