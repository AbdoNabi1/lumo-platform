{
  "name": "@platform/messaging",
  "version": "0.0.0",
  "private": true,
  "description": "Event backbone runtime: transactional outbox write-side, publisher/consumer abstractions, idempotency, retry, and DLQ, with in-memory adapters. Broker-agnostic; Redpanda/Debezium adapters added later.",
