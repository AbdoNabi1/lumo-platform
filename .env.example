# ─────────────────────────────────────────────────────────────────────────────
# Environment example — copy to .env.local (never commit real values; NO secrets).
# Validated at boot by @platform/config (src/env.ts). See docs/development/SETUP.md.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode (Node convention)
NODE_ENV=development

# Deployment environment: local | development | staging | production
APP_ENV=local

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# Public base URL of the web app (exposed to the browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web app port
PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# Server-side infrastructure (validated by @platform/config/server). Values below
# match infrastructure/docker/docker-compose.yml for local dev. NO production secrets —
# those come from the secret manager / Vault. Any var also supports a `*_FILE` variant
# (Docker/K8s secrets), e.g. DATABASE_URL_FILE=/run/secrets/database_url.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql://lumo:lumo@localhost:5432/lumo
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_LOG_QUERIES=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lumo:

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=lumo
CLICKHOUSE_PASSWORD=lumo
CLICKHOUSE_DATABASE=lumo

# Object storage (S3-compatible / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_BUCKET_MEDIA=media
S3_BUCKET_EXPORTS=exports
S3_BUCKET_BACKUPS=backups

# Observability (OpenTelemetry)
OTEL_SERVICE_NAME=lumo-service
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_ENABLED=false
OTEL_METRICS_ENABLED=false

# Backups (configuration only; execution operated outside the app)
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_BUCKET=backups
